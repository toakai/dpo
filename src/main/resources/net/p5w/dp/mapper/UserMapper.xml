<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.p5w.dp.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="net.p5w.dp.entity.User">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <result column="username" jdbcType="VARCHAR" property="username"/>
        <result column="password" jdbcType="VARCHAR" property="password"/>
        <result column="real_name" jdbcType="VARCHAR" property="realName"/>
        <result column="phone" jdbcType="VARCHAR" property="phone"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="update_time" jdbcType="TIMESTAMP" property="updateTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, `password`, real_name, phone, create_time, update_time
    </sql>

    <!-- 根据主键查询用户 -->
    <select id="getById" parameterType="java.lang.Long" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM p5w_user
        WHERE id = #{id,jdbcType=BIGINT}
    </select>

    <!-- 根据主键删除用户 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM p5w_user WHERE id = #{id,jdbcType=BIGINT}
    </delete>

    <!-- 新增用户（主键自增回填） -->
    <insert id="insert" keyColumn="id" keyProperty="id" parameterType="net.p5w.dp.entity.User" useGeneratedKeys="true">
        INSERT INTO p5w_user (username, `password`, real_name, phone, create_time)
        VALUES (#{username,jdbcType=VARCHAR}, #{password,jdbcType=VARCHAR}, #{realName,jdbcType=VARCHAR},
                #{phone,jdbcType=VARCHAR}, #{createTime,jdbcType=TIMESTAMP})
    </insert>

    <!-- 根据主键更新用户 -->
    <update id="updateById" parameterType="net.p5w.dp.entity.User">
        UPDATE p5w_user
        SET username    = #{username,jdbcType=VARCHAR},
            `password`  = #{password,jdbcType=VARCHAR},
            real_name   = #{realName,jdbcType=VARCHAR},
            phone       = #{phone,jdbcType=VARCHAR},
            update_time = #{updateTime,jdbcType=TIMESTAMP}
        WHERE id = #{id,jdbcType=BIGINT}
    </update>

    <!-- 查询全部用户（不分页） -->
    <select id="list" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM p5w_user
    </select>

    <!-- 按条件分页查询用户（配合 PageHelper 分页插件） -->
    <select id="selectUserList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM p5w_user
        <where>
            <if test="username != null and username != ''">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY id DESC
    </select>

</mapper>
